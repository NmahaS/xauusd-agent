# Required — IG broker (price + market data + sentiment)
IG_API_KEY=                 # My IG → Settings → API
IG_USERNAME=                # Your IG login email
IG_PASSWORD=                # Your IG login password
IG_DEMO=true                # true = demo prices, false = live prices

# Required — LLM + notifications
ANTHROPIC_API_KEY=          # Primary — Claude Haiku 4.5
DEEPSEEK_API_KEY=           # Consensus — DeepSeek Chat
PERPLEXITY_API_KEY=         # News (optional) — Perplexity Sonar Pro
DEEPSEEK_MODEL=deepseek-chat
TELEGRAM_BOT_TOKEN=         # Bot from @BotFather
TELEGRAM_CHAT_ID=           # Your chat ID

# Optional (enhance analysis quality)
FRED_API_KEY=               # Federal Reserve macro data

# Trading config — IG Australia, AUD gold futures JUN-26
SYMBOL=XAU/AUD
CURRENCY=AUD
EXECUTION_TF=1h
BIAS_TF=4h
CANDLES_LOOKBACK=200
DEFAULT_RISK_PCT=1
DEFAULT_RR_MIN=2

# Execution gates
AUTO_TRADE=false             # ONLY set true after backtest confirms positive expectancy
DRY_EXECUTE=true             # true = run all checks but skip actual IG order placement

# Dev
DRY_RUN=false

# Cloudflare Worker + GitHub integration
GITHUB_TOKEN=               # Fine-grained PAT: contents:read + actions:write
GITHUB_REPO=                # e.g. NmahaS/xauusd-agent
